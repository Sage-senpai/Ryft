# =============================================================================
# RYFT — Environment Variables
# Owner: KAI
# Every var required for local dev + Vercel + Railway must be listed here.
# =============================================================================

# --- Initia chain -----------------------------------------------------------
# Until ryft-1 is deployed via weave, leave this as interwoven-1 (Initia
# testnet). InterwovenKit's chain registry knows interwoven-1 out of the box
# and will crash with "Chain not found" if defaultChainId is unknown.
# Flip to ryft-1 AFTER running docs/deploy-runbook.md AND adding a customChain
# entry in packages/web/src/app/providers.tsx.
NEXT_PUBLIC_CHAIN_ID=interwoven-1
NEXT_PUBLIC_CHAIN_NAME=RYFT
NEXT_PUBLIC_RPC_URL=
NEXT_PUBLIC_REST_URL=
NEXT_PUBLIC_FAUCET_URL=
NEXT_PUBLIC_EXPLORER_URL=

# Initia L1 (used only for .init username resolution via Move view call)
NEXT_PUBLIC_L1_REST_URL=https://rest.testnet.initia.xyz
NEXT_PUBLIC_L1_USERNAMES_MODULE=0x42cd8467b1c86e59bf319e5664a09b6b5840bb3fac64f5ce690b5041c530565a

# --- Contract addresses (VERA fills after first deploy) ---------------------
NEXT_PUBLIC_CONTRACT_RYFT_CARD_REGISTRY=
NEXT_PUBLIC_CONTRACT_RYFT_BATTLE=
NEXT_PUBLIC_CONTRACT_RYFT_SESSION=

# --- AutoSign (session keys) ------------------------------------------------
# Allowed msg type URLs. Scoped to ryft_battle execute only.
NEXT_PUBLIC_AUTOSIGN_MSG_TYPES=/cosmwasm.wasm.v1.MsgExecuteContract
NEXT_PUBLIC_AUTOSIGN_TTL_SECONDS=3600

# --- Matchmaking server -----------------------------------------------------
NEXT_PUBLIC_MATCHMAKING_WS_URL=ws://localhost:3001
MATCHMAKING_PORT=3001
MATCHMAKING_REDIS_URL=

# --- Server-side signing (demo fallback wallet — never commit real key) -----
DEMO_OPERATOR_MNEMONIC=

# --- CI / deployment --------------------------------------------------------
VERCEL_TOKEN=
RAILWAY_TOKEN=
GH_TOKEN=
