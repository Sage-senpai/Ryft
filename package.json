{
  "name": "ryft",
  "version": "0.0.1",
  "private": true,
  "description": "RYFT — Cross-chain animated card battle game on Initia",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "postinstall": "node scripts/patch-cosmjs-exports.mjs",
    "build": "turbo run build",
    "dev": "turbo run dev --filter=@ryft/web --filter=@ryft/server",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules",
    "finalize": "node scripts/finalize-submission.mjs"
  },
  "devDependencies": {
    "turbo": "^2.1.3",
    "typescript": "^5.6.3",
    "@types/node": "^20.16.11"
  },
  "pnpm": {
    "overrides": {
      "ky": "^1.8.2"
    }
  },
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.12.0"
  }
}
